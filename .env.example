# Firebase client config for future Firestore mode
# Copy this file to .env.local for local development.
# In Vercel, add the same keys under Project Settings > Environment Variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Storage mode plan
# local: current mock mode using browser localStorage
# firestore: future real-time multi-device mode
VITE_STORAGE_MODE=local
